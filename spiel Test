# UPDATE

def update(dt):
global verbleibende_zeit, spiel_vorbei, gewonnen
global wetter, wetter_timer
global tier_dx, tier_dy
global tier_bewegungs_timer, tier_animation_timer, tier_animation_frame, tier_richtung
global game_over_sound_gespielt

```
if spiel_vorbei or gewonnen:
    return

for gy in range(GITTER_ZEILEN):
    for gx in range(GITTER_SPALTEN):
        kachel = farm[gy][gx]
        if kachel["status"] == "wachsend":
            speed = 1.5 if wetter == "Sonne" else 2.5
            if kachel["gewaessert"]:
                speed *= 1.3
            kachel["timer"] += speed * dt
            if kachel["timer"] >= PFLANZEN[kachel["pflanze"]]["wachszeit"]:
                kachel["status"] = "bereit"
                beet_actor_aktualisieren(gx, gy)

# Wasser-Partikel 
for p in wasser_partikel[:]:
    p["x"]     += p["dx"]
    p["y"]     += p["dy"]
    p["leben"] -= dt * 1.8
    if p["leben"] <= 0:
        wasser_partikel.remove(p)

# Wetterwechsel
wetter_timer += dt
if wetter_timer >= WETTER_INTERVALL:
    wetter_timer = 0.0
    wetter = random.choice(["Sonne", "Sonne", "Regen"])
    wetter_icon.image = "wetter_sonne" if wetter == "Sonne" else "wetter_regen"

# Zeit-Countdown
verbleibende_zeit -= dt
if verbleibende_zeit <= 0:
    verbleibende_zeit = 0
    spiel_vorbei = True
    if not game_over_sound_gespielt:
        game_over_sound_gespielt = True
        sound_abspielen("game_over")

# Level-Up
if geld >= level_ziel:
    level_aufsteigen()

# Tier bewegen 
tier_bewegungs_timer -= dt
if tier_bewegungs_timer <= 0:
    tier_bewegungs_timer = random.uniform(0.6, 1.8)
    tier_dx = random.randint(-2, 2)
    tier_dy = random.randint(-1, 1)
    if tier_dx < 0:
        tier_richtung = "links"
    elif tier_dx > 0:
        tier_richtung = "rechts"
    else:
        tier_richtung = "stehend"

tier.x = max(20, min(WIDTH - 20, tier.x + tier_dx))
tier.y = max(FARM_HOEHE - 65, min(FARM_HOEHE - 15, tier.y + tier_dy))

# ---- Tier-Animation ----
if tier_richtung != "stehend":
    tier_animation_timer += dt
    if tier_animation_timer >= 0.25:
        tier_animation_timer = 0.0
        tier_animation_frame = 1 - tier_animation_frame
frames = TIER_FRAMES[tier_richtung]
tier.image = frames[tier_animation_frame % len(frames)]
```

