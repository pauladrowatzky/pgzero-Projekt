def wachstum_fortschritt(kachel):
if kachel[“pflanze”] is None:
return 0.0
return min(kachel[“timer”] / PFLANZEN[kachel[“pflanze”]][“wachszeit”], 1.0)

def abgerundetes_rechteck(farbe, rx, ry, rw, rh, radius=10):
screen.draw.filled_rect(Rect(rx + radius, ry,          rw - 2*radius, rh),           farbe)
screen.draw.filled_rect(Rect(rx,          ry + radius,  rw,           rh - 2*radius), farbe)
for ex, ey in [(rx+radius, ry+radius), (rx+rw-radius, ry+radius),
(rx+radius, ry+rh-radius), (rx+rw-radius, ry+rh-radius)]:
screen.draw.filled_circle((ex, ey), radius, farbe)

# SPIELMECHANIK

def pflanzen(gx, gy):
global geld
kachel  = farm[gy][gx]
p       = PFLANZEN[ausgewaehlte_pflanze]
if geld >= p[“kosten”]:
kachel[“status”]     = “wachsend”
kachel[“timer”]      = 0.0
kachel[“pflanze”]    = ausgewaehlte_pflanze
kachel[“gewaessert”] = False
geld -= p[“kosten”]
beet_actor_aktualisieren(gx, gy)
sound_abspielen(“pflanzen”)

def giessen(gx, gy):
kachel = farm[gy][gx]
if kachel[“status”] == “wachsend”:
kachel[“timer”]      += 2.0
kachel[“gewaessert”] = True
sound_abspielen(“giessen”)
# Wasser-Partikel erzeugen
mx = gx * KACHEL_GROESSE + KACHEL_GROESSE // 2
my = gy * KACHEL_GROESSE + KACHEL_GROESSE // 2
for _ in range(10):
wasser_partikel.append({
“x”:     mx + random.randint(-25, 25),
“y”:     my + random.randint(-20, 20),
“dx”:    random.uniform(-1.5, 1.5),
“dy”:    random.uniform(-3.0, -0.5),
“leben”: 1.0,
})

def ernten(gx, gy):
global geld
kachel = farm[gy][gx]
if kachel[“status”] == “bereit”:
geld += PFLANZEN[kachel[“pflanze”]][“gewinn”]
kachel[“status”]     = “leer”
kachel[“timer”]      = 0.0
kachel[“pflanze”]    = None
kachel[“gewaessert”] = False
beet_actor_aktualisieren(gx, gy)
sound_abspielen(“ernten”)

def level_aufsteigen():
global level, level_ziel, verbleibende_zeit, gewonnen
if level >= 3:
gewonnen = True
return
level     += 1
level_ziel = int(level_ziel * 2.2)
verbleibende_zeit = max(verbleibende_zeit, 60.0) + 30.0
sound_abspielen(“level_up”)

# MAUS-INTERAKTION

def on_mouse_down(pos):
global ausgewaehlte_pflanze
if spiel_vorbei or gewonnen:
    return

# SHOP
shop_x = 70
for name in PFLANZEN_LISTE:
    if shop_x <= pos[0] <= shop_x + 100 and FARM_HOEHE + 38 <= pos[1] <= FARM_HOEHE + 90:
        ausgewaehlte_pflanze = name
        return
    shop_x += 108

#Beet anklicken
for gy in range(GITTER_ZEILEN):
    for gx in range(GITTER_SPALTEN):
        if beet_actors[gy][gx].collidepoint(pos):
            kachel = farm[gy][gx]
            if kachel["status"] == "leer":
                pflanzen(gx, gy)
            elif kachel["status"] == "wachsend":
                giessen(gx, gy)
            elif kachel["status"] == "bereit":
                ernten(gx, gy)
            return
