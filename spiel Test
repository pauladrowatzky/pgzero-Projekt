def beet_actor_aktualisieren(gx, gy):
“”“Setzt das Beet-Actor-Bild passend zum Spielstatus.”””
status = farm[gy][gx][“status”]
if status == “leer”:
beet_actors[gy][gx].image = “beet_leer”
